# Configuração de E-mail - Linux SSH Diagnostics
# ================================================
# Copie este arquivo para .env e preencha com suas credenciais reais.
#   cp .env.example .env
#
# Para obter uma App Password do Gmail:
#   1. Acesse myaccount.google.com
#   2. Segurança → Verificação em duas etapas (ative se não estiver ativo)
#   3. Segurança → Senhas de app → Criar nova
#   4. Copie a senha gerada (16 caracteres) para GMAIL_APP_PASSWORD

EMAIL_DEST="destino@example.com"
GMAIL_USER="seu.email@gmail.com"
GMAIL_APP_PASSWORD="xxxx xxxx xxxx xxxx"
